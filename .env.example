# ─── API Keys ────────────────────────────────────────────────────────────────
# These are only used in development (Vite dev server).
# In production, set them as Vercel environment variables instead.

# Premiumize API key — https://premiumize.me/account
# (Optional in dev — can also be set in Settings UI)
VITE_PM_API_KEY=

# TMDB API key (v3) — https://www.themoviedb.org/settings/api
# (Optional in dev — can also be set in Settings UI)
VITE_TMDB_API_KEY=

# SceneNZBs API key — https://scenenzbs.com
# Only needed for dev (Vite proxy). In production the Vercel function adds it server-side.
VITE_SCENENZBS_API_KEY=

# ─── Proxy Settings ──────────────────────────────────────────────────────────
# Set to "true" to route TMDB calls through /api/tmdb Vercel function
# (keeps your TMDB key server-side). Leave blank to use the key client-side.
VITE_TMDB_USE_PROXY=
